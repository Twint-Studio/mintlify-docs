{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "maple",
  "name": "Twint",
  "colors": {
    "primary": "#641ae6",
    "light": "#875bf5",
    "dark": "#4f15b8"
  },
  "favicon": "/favicon.svg",
  "appearance": {
    "strict": true
  },
  "navigation": {
    "pages": [
      "index",
      {
        "group": "OpenAPI",
        "openapi": "openapi/openapi.json"
      },
      {
        "group": "Lamar",
        "pages": ["lamar/custom"]
      }
    ]
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Website",
        "href": "https://twint.us.kg/"
      },
      {
        "label": "GitHub",
        "href": "https://github.com/Twint-Studio"
      },
      {
        "label": "Git",
        "href": "https://git.serversmp.xyz/TwintStudio"
      }
    ]
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "perplexity"
    ]
  }
}
